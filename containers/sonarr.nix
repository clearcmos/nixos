{ pkgs, lib, config, ... }:
{
  # Auto-created directory rules
  systemd.tmpfiles.rules = [
    "d /var/lib/containers/storage/volumes/sonarr/data 0755 root root - -"
  ];
  # Auto-created image pull service
  systemd.services."pull-sonarr-sonarr-latest-image" = {
    description = "Pull latest sonarr:latest image for sonarr";
    path = [ pkgs.podman ];
    script = ''
      podman pull lscr.io/linuxserver/sonarr:latest
    '';
    serviceConfig = {
      Type = "oneshot";
    };
    wantedBy = [ "multi-user.target" ];
  };


  # Auto-created service to ensure volume directories exist before container start
  systemd.services."ensure-sonarr-volumes" = {
    description = "Ensure volume directories exist for sonarr";
    after = [ "systemd-tmpfiles-setup.service" ];
    before = [ "podman-sonarr.service" ];
    requiredBy = [ "podman-sonarr.service" ];
    serviceConfig = {
      Type = "oneshot";
      RemainAfterExit = true;
      ExecStart = "${pkgs.bash}/bin/bash -c \"mkdir -p /var/lib/containers/storage/volumes/sonarr/data; \"";
    };
  };


  # Runtime
  virtualisation.podman = {
    enable = true;
    autoPrune.enable = true;
    dockerCompat = true;
  };

  # Enable container name DNS for all Podman networks.
  networking.firewall.interfaces = let
    matchAll = if !config.networking.nftables.enable then "podman+" else "podman*";
  in {
    "${matchAll}".allowedUDPPorts = [ 53 ];
  };

  virtualisation.oci-containers.backend = "podman";

  # Containers
  virtualisation.oci-containers.containers."sonarr" = {
    image = "lscr.io/linuxserver/sonarr:latest";
    environment = {
      "PGID" = "0";
      "PUID" = "0";
      "TZ" = "America/New_York";
    };
    volumes = [
      "/var/lib/containers/storage/volumes/sonarr/data:/config:rw"
      "/mnt/syno/downloads:/downloads:rw"
      "/mnt/syno/videos/tv:/tv:rw"
    ];
    log-driver = "journald";
    extraOptions = [
      "--network=host"
    ];
  };
  systemd.services."podman-sonarr" = {
    serviceConfig = {
      Restart = lib.mkOverride 90 "no";
    };
    partOf = [
      "podman-compose-sonarr-root.target"
    ];
    wantedBy = [
      "podman-compose-sonarr-root.target"
    ];
  };

  # Root service
  # When started, this will automatically create all resources and start
  # the containers. When stopped, this will teardown all resources.
  systemd.targets."podman-compose-sonarr-root" = {
    unitConfig = {
      Description = "Root target generated by compose2nix.";
    };
    wantedBy = [ "multi-user.target" ];
  };
}
